# EditorConfig - https://editorconfig.org
# Helps maintain consistent coding styles across different editors and IDEs

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{js,json}]
indent_size = 2

[*.{scss,css}]
indent_size = 2

[*.yml]
indent_size = 2
